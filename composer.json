{
  "name": "pom/pom-framework",
  "description": "A WordPress settings framework for rendering fields and persisting configuration.",
  "type": "library",
  "authors": [
    {
      "name": "POM",
      "email": "info@pom.es"
    }
  ],
  "license": "MIT",
  "require": {
    "php": ">=7.4",
    "select2/select2": "4.0.13",
    "ext-json": "*",
    "cerdic/css-tidy": "v2.0.1",
    "ext-zend-opcache": "*",
    "ext-fileinfo": "*"
  },
  "autoload": {
    "psr-4": {
      "POMFramework\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true
  },
  "minimum-stability": "dev",
  "prefer-stable" : true
}
